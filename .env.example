# App mode: production (default) | testnet (Sepolia scaffold — no separate deploy yet)
VITE_APP_MODE=production

# Live on-chain execution — keep false for Alpha / production preview
VITE_ENABLE_LIVE_EXECUTION=false

# Mainnet single-leg buy pilot — keep false unless explicitly testing
VITE_ENABLE_MAINNET_EXECUTION=false

# Top-level alpha / preview banners (default on; set false to hide)
VITE_SHOW_ALPHA_WARNINGS=true

# WalletConnect Cloud project ID (https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=

# PortX backend quote API (frontend calls backend — never expose DEX API keys client-side)
VITE_PORTX_API_URL=http://localhost:8080

# Use local mocked quote providers when true; set false to prefer backend API
VITE_ENABLE_DEMO_QUOTES=true

# Optional: RPC overrides
# VITE_ALCHEMY_KEY=your_alchemy_key

# Optional: only used when backend is not available (prefer backend proxy)
# VITE_ZEROX_API_KEY=
